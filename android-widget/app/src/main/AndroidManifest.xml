<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.WaterTracker">

        <!-- Main Activity (minimal, just for app icon) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.WaterTracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Widget Receiver -->
        <receiver
            android:name=".WaterTrackerWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/water_tracker_widget_info" />
        </receiver>

        <!-- Pebble watch sync (PebbleKit 2). The Core Devices app binds this service
             to deliver AppMessages (RequestSync / LogOz) and app-open events. -->
        <service
            android:name=".pebble.PebbleListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="io.rebble.pebblekit2.RECEIVE_DATA_FROM_WATCH" />
            </intent-filter>
        </service>

    </application>

</manifest>
